#include <iostream>

int main() {

    int Num_1 = 100;
    int Num_2 = 50;

    std::cout << "Addition of two numbers is: " << Num_1 + Num_2 << std::endl;
    std::cout << "Subtraction of two numbers is: " << Num_1 - Num_2 << std::endl;
    std::cout << "Multiplication of two numbers is: " << Num_1 * Num_2 << std::endl;
    std::cout << "Division of two numbers is: " << Num_1 / Num_2 << std::endl;

    return 0;
}